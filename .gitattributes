# Normalize text files and let Git manage line endings safely across platforms
* text=auto

# Keep build and CMake scripts stable (especially generated plugin files)
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Common source and config files
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.dart text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.gitignore text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
